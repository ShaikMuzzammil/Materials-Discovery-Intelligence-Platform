# MatDiscoverAI Environment Variables
# Copy this file to .env and fill in your values

# Database Connection (SQLite for development)
DATABASE_URL="file:./db/custom.db"

# For production, use external database:
# DATABASE_URL="postgresql://user:pass@host:5432/matdiscoverai"
# DATABASE_URL="libsql://matdiscoverai-xxx.turso.io"
# DATABASE_URL="mysql://user:pass@host:3306/matdiscoverai"

# Application
NODE_ENV="development"

# Optional: OpenAI API Key (for enhanced AI features)
# OPENAI_API_KEY="sk-..."

# Optional: App URL (auto-detected in most cases)
# NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
