# Files to exclude from Vercel deployment (reduces function size)
# These are not needed in the serverless function

# Heavy ML artifacts (use pre-trained .pkl files instead)
ml/knowledge_graph/
ml/evaluation/__pycache__/
ml/datasets/__pycache__/
ml/features/__pycache__/
ml/models/__pycache__/
ml/nlp/__pycache__/
ml/llm/__pycache__/
ml/__pycache__/
backend/__pycache__/
backend/apps/*/__pycache__/
backend/apps/*/migrations/__pycache__/

# Test files
**/tests/
**/test_*.py
**/*_tests.py

# Documentation (not needed at runtime)
docs/
*.md
!README.md

# CI/CD configs
.github/
.gitlab-ci.yml

# Docker (not needed on Vercel)
Dockerfile
docker-compose.yml
render.yaml

# Dev tools
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Coverage
.coverage
htmlcov/
.tox/
.pytest_cache/

# Local databases
db.sqlite3
db.sqlite3-journal
*.sqlite3

# Celery
celerybeat-schedule
celerybeat.pid

# Jupyter
.ipynb_checkpoints

# Virtual envs
venv/
env/
.venv/

# Log files
*.log

# ChromaDB (not persistent on Vercel)
chroma_db/

# Local static files (regenerated by collectstatic)
staticfiles/
media/
