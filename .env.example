# ============================================================
# MatDiscoverAI - Environment Variables Example
# Copy to .env and fill in your real values
# ============================================================

# ---------- Django Core ----------
DJANGO_SECRET_KEY=django-insecure-change-me-to-a-50-char-random-string-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,.vercel.app
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://*.onrender.com

# ---------- Database ----------
# Use SQLite for local dev; PostgreSQL for production
DATABASE_URL=sqlite:///db.sqlite3
# For Render/Heroku Postgres:
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ---------- Redis / Celery ----------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------- LLM Providers ----------
# Option 1: OpenAI (recommended, paid)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
# Option 2: Groq (fast + free tier)
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192
# Option 3: Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
# Option 4: Hugging Face (free, used for embeddings + fallback LLM)
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ---------- Embedding Model ----------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Materials-science tuned: PractELI/MatSciBERT  (heavier, optional)

# ---------- Vector DB ----------
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=matdiscoverai_papers

# ---------- Knowledge Graph ----------
# Use NetworkX in-process for dev; Neo4j for production scale
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=yourpassword

# ---------- External Data APIs ----------
# Materials Project (free, register at https://nextgen.materialsproject.org)
MATERIALS_PROJECT_API_KEY=
# arXiv API (free, no key needed)
ARXIV_API_URL=http://export.arxiv.org/api/query
# Semantic Scholar (free, optional key for higher rate limit)
SEMANTIC_SCHOLAR_API_KEY=
# OpenAlex (free, no key needed; polite email recommended)
OPENALEX_EMAIL=your-email@example.com
# CrossRef (free)
CROSSREF_API_URL=https://api.crossref.org/works

# ---------- Security / Production ----------
SENTRY_DSN=
DJANGO_SECURE_SSL_REDIRECT=False

# ---------- App Config ----------
APP_NAME=MatDiscoverAI
APP_VERSION=1.0.0
DEFAULT_DOMAIN_FOCUS=battery
